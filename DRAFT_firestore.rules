rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // Phase 3: Global Helpers
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // Bootstrapped admin: practicalcharacter@gmail.com
      return isSignedIn() && (
        request.auth.token.email == 'practicalcharacter@gmail.com' && request.auth.token.email_verified == true
      );
    }

    // -------------------------------------------------------------------------
    // Pillar 0: Global Safety Net
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Pillar 2: Validation Blueprints
    // -------------------------------------------------------------------------

    function isValidScript(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 100
          && data.description is string && data.description.size() <= 2000
          && data.price is number && data.price >= 0
          && data.game is string && data.game.size() <= 100
          && data.authorId == request.auth.uid
          && data.authorName is string
          && (data.tags == null || (data.tags is list && data.tags.size() <= 10))
          && (data.features == null || (data.features is list && data.features.size() <= 20))
          && data.createdAt == request.time;
    }

    function isValidUserProfile(data) {
       return data.uid == request.auth.uid
          && data.email == request.auth.token.email
          && data.balance == 0 // Initial balance must be 0
          && data.role == 'user' // Users can't set their own roles
          && data.createdAt == request.time;
    }

    // -------------------------------------------------------------------------
    // Phase 4: Path Match Blocks
    // -------------------------------------------------------------------------

    match /scripts/{scriptId} {
      allow read: if true; // Public listings
      allow create: if isEmailVerified() && isValidScript(incoming());
      allow update: if isEmailVerified() && (
        isAdmin() || 
        (isOwner(existing().authorId) && 
         incoming().authorId == existing().authorId &&
         incoming().createdAt == existing().createdAt &&
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'game', 'tags', 'features', 'thumbnailUrl', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );
      allow delete: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isEmailVerified() && 
                      incoming().userId == request.auth.uid &&
                      incoming().timestamp == request.time;
        allow delete: if isAdmin() || isOwner(existing().userId);
      }

      match /private/data {
        // Only someone who has purchased the script or the author or admin can see the code
        allow read: if isAdmin() || 
                    isOwner(get(/databases/$(database)/documents/scripts/$(scriptId)).data.authorId) ||
                    exists(/databases/$(database)/documents/purchases/$(request.auth.uid + "_" + scriptId));
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isEmailVerified() && isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && (
        incoming().uid == existing().uid &&
        incoming().email == existing().email &&
        incoming().role == existing().role && // Can't change own role
        incoming().balance == existing().balance && // User can't update their own balance (must be via server/logic)
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'avatarUrl', 'purchasedScriptIds'])
      ) || isAdmin();
    }

    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // For now, satisfy the "purchase" creation logic
      // In a real app, this might be restricted to server-side only
      allow create: if isEmailVerified() && 
                    incoming().userId == request.auth.uid &&
                    incoming().timestamp == request.time &&
                    purchaseId == (request.auth.uid + "_" + incoming().scriptId);
    }
  }
}
